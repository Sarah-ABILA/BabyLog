
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BabyLog — Profil enfant</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  </head>
  <body>
  <div class="phone">

    <!-- Header avec avatar -->
    <div class="profile-header">
      <a href="#" class="profile-header__back">‹</a>
      <span class="profile-header__title">Profil de bébé</span>
      <div class="profile-header__avatar">👶</div>
    </div>

    <div class="profile-body">

      <!-- Nom + âge -->
      <div class="profile-name">
        <h2>Emma</h2>
        <span class="age-badge">8 mois</span>
      </div>

      <!-- Card formulaire -->
      <div class="profile-card">
        <p class="profile-card__section-title">Informations</p>

        <!-- Prénom -->
        <div class="form-field">
          <label>Prénom</label>
          <div class="input-wrap">
            <span class="input-icon">✏️</span>
            <input type="text" value="Emma" placeholder="Ex : Emma">
          </div>
        </div>

        <!-- Date de naissance -->
        <div class="form-field">
          <label>Date de naissance</label>
          <div class="input-wrap">
            <span class="input-icon">🎂</span>
            <input type="date" value="2024-07-11">
          </div>
        </div>

        <!-- Poids -->
        <div class="form-field">
          <label>Poids</label>
          <div class="input-wrap">
            <span class="input-icon">⚖️</span>
            <input type="number" value="7.8" step="0.1" class="with-suffix">
            <span class="input-suffix">kg</span>
          </div>
        </div>

        <!-- Médecin traitant -->
        <div class="form-field">
          <label>Médecin traitant</label>
          <div class="input-wrap">
            <span class="input-icon">🩺</span>
            <input type="text" value="Dr. Martin" placeholder="Ex : Dr. Dupont">
          </div>
          <span class="hint">Facultatif</span>
        </div>

        <div class="form-divider"></div>

        <button class="btn-submit">Mettre à jour 💾</button>
        <button class="btn-danger">🗑 Supprimer ce profil</button>

      </div>

      <p class="form-note">Les modifications sont sauvegardées immédiatement</p>
    </div>

    <!-- Bottom nav -->
    <nav class="bottom-nav">
      <a href="#" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg>
        Page d'accueil
      </a>
      <a href="#" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><polyline points="9 11 12 14 22 4"/></svg>
        Suivi vaccins
      </a>
      <a href="#" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Historique
      </a>
      <a href="#" class="nav-item nav-item--active">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profil
      </a>
    </nav>

  </div>
  </body>
</html>
