<%# app/views/shared/_bottom_nav.html.erb %>

<nav class="bottom-nav">

<%# ── Accueil ── %>
<%= link_to root_path,
  class: "bottom-nav__item #{current_page?(root_path) ? 'bottom-nav__item--active' : ''}" do %>
  <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
  <polyline points="9 21 9 12 15 12 15 21"/>
  </svg>
  <span class="bottom-nav__label">Page d'accueil</span>
<% end %>

<%# ── Suivi vaccins ── %>
<% vac_path = defined?(@child) && @child ? child_vaccinations_path(@child) : "#" %>
  <%= link_to vac_path,
  class: "bottom-nav__item #{controller_name == 'vaccinations' ? 'bottom-nav__item--active' : ''} #{vac_path == '#' ? 'bottom-nav__item--disabled' : ''}" do %>
  <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/>
  <polyline points="9 11 12 14 22 4"/>
  </svg>
  <span class="bottom-nav__label">Suivi vaccins</span>
<% end %>

<%# ── Historique ── %>
<% hist_path = defined?(@child) && @child ? child_chats_path(@child) : "/chats" %>
  <%= link_to hist_path,
  class: "bottom-nav__item #{controller_name == 'chats' ? 'bottom-nav__item--active' : ''} #{hist_path == '#' ? 'bottom-nav__item--disabled' : ''}" do %>
  <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
  <polyline points="14 2 14 8 20 8"/>
  <line x1="16" y1="13" x2="8" y2="13"/>
  <line x1="16" y1="17" x2="8" y2="17"/>
  </svg>
  <span class="bottom-nav__label">Historique</span>
<% end %>

<%# ── Profil ── %>
<%= link_to user_signed_in? ? edit_user_registration_path : new_user_session_path,
class: "bottom-nav__item #{controller_name == 'profiles' ? 'bottom-nav__item--active' : ''}" do %>
  <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
    <circle cx="12" cy="7" r="4"/>
  </svg>
  <span class="bottom-nav__label">Profil</span>
<% end %>
</nav>
