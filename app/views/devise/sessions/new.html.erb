<div class="hero-container text-center position-relative mb-5 rounded-5">
  <div class="col"><%= image_tag "Logo.png", alt: "logo babylog", class:"avatar" %></div>
  <p class="fw-semibold fs-4">Connexion</p>
</div>
<div class="container align-center col-8 mt-5">
<%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="form-inputs">
    <%= f.input :email,
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email" } %>
    <%= f.input :password,
                required: false,
                input_html: { autocomplete: "current-password" } %>
    <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
  </div>

  <div class="form-actions mb-5">
    <%= f.button :submit, "Se connecter", class: "btn-question" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
</div>
