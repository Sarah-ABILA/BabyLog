<div class="hero-container text-center position-relative mb-5 rounded-5">
  <div class="col"><%= image_tag "Logo.png", alt: "logo babylog", class:"avatar" %></div>
  <p class="fw-semibold fs-4">Mot de passe oublié ?</p>
</div>
<div class="container align-center col-8 mt-5">
  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= f.error_notification %>

    <div class="form-inputs">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  input_html: { autocomplete: "email" } %>
    </div>

    <div class="form-actions">
      <%= f.button :submit, "Recevoir les instructions", class: "btn-question mb-5" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
