<%= render "results/title" %>

<div class="chat-page">
  <div class="chat-wrapper">

    <!-- ===== HEADER CHAT ===== -->
    <div class="chat-header-card">
      <h2 class="chat-title"><%= @chat.title %></h2>

      <p class="chat-persona">
        Profil : <strong><%= @chat.persona %></strong>
      </p>

      <% if current_user.user_babies.any? %>
        <% baby = current_user.user_babies.last %>
        <% age_in_months = ((Date.current.year * 12 + Date.current.month) - (baby.birth_date.year * 12 + baby.birth_date.month)) %>

        <div class="baby-info">
          <span class="baby-pill">
            Bébé : <strong><%= baby.name %></strong>
          </span>

          <span class="baby-pill">
            Âge : <strong><%= age_in_months %> mois</strong>
          </span>

          <span class="baby-pill">
            Poids : <strong><%= baby.weight %> kg</strong>
          </span>
        </div>
      <% end %>
    </div>

    <!-- ===== MESSAGES ===== -->
    <div class="chat-card">

      <div class="messages-container">

        <% @chat.messages.each do |message| %>

          <% if message.role == "user" %>

            <div class="message message-user">
              <div class="message-bubble">
                <%= message.content %>
              </div>
            </div>

          <% else %>

            <div class="message message-ai">
              <div class="message-bubble">
                <%= message.content %>
              </div>
            </div>

          <% end %>

        <% end %>

      </div>

      <!-- ===== FORM MESSAGE ===== -->
      <div class="chat-input">

        <%= form_with url: chat_messages_path(@chat), method: :post, local: true do |f| %>

          <%= text_field_tag :content,
            nil,
            placeholder: "Posez votre question...",
            class: "chat-text-input"
          %>

          <%= submit_tag "Envoyer", class: "chat-send-btn" %>

        <% end %>

      </div>

    </div>

    <!-- ===== ACTION RESULT ===== -->
    <div class="chat-actions">

      <%= button_to "Générer mon plan BabyLog",
        chat_results_path(@chat),
        method: :post,
        class: "generate-plan-btn"
      %>

    </div>

    <!-- ===== BACK ===== -->
    <div class="back-home">
      <%= link_to "Retour à l'accueil", root_path, class: "home-link-btn" %>
    </div>

  </div>
</div>
