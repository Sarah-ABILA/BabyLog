<div id="<%= dom_id(message) %>" class="message <%= message.role == 'user' ? 'message-user' : 'message-ai' %>">
  <div class="message-bubble">
    <% if message.role == "assistant" %>
      <%= message.content.present? ? simple_format(message.content) : '...' %>
    <% else %>
      <%= message.content %>
    <% end %>
  </div>
</div>
